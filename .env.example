# Base URL of the worktide backend API the portal talks to.
# Dev (local ddev backend): the worktide API host.
# Prod: the portal is served on its own domain; point this at the public API.
VITE_API_BASE=/v1

# Mercure hub URL for live notifications (bell + Benachrichtigungen page).
# Dev: a same-origin path (`/.well-known/mercure`) proxied by Vite to the hub
# (see vite.config.ts) so the SSE stream dodges the shared hub's CORS allowlist.
# Prod: point straight at the hub, e.g.
#   VITE_MERCURE_HUB_URL=https://worktide-mercure.example.com/.well-known/mercure
# (the hub's cors_origins must then list the real portal domain).
VITE_MERCURE_HUB_URL=/.well-known/mercure
